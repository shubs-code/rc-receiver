<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Permissions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.CHANGE_NETWORK_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />

    <!-- USB Serial -->
    <uses-feature
        android:name="android.hardware.usb.host"
        android:required="true" />
    <!-- Add this permission -->
    <uses-permission android:name="android.permission.USB_PERMISSION" />

    <!-- Sensors -->
    <uses-feature
        android:name="android.hardware.sensor.compass"
        android:required="true" />
    <uses-feature
        android:name="android.hardware.sensor.accelerometer"
        android:required="true" />
    <uses-feature
        android:name="android.hardware.location.gps"
        android:required="false" />

    <application
        android:name=".RCReceiverApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.RCReceiver" >
        <activity
            android:name=".presentation.MainActivity"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>
        <!-- ✅ USB DEVICE RECEIVER - System-Integrated -->
        <!-- This receiver automatically gets system permission dialogs -->
        <receiver
            android:name="com.shubham.rcreceiver.receivers.UsbDeviceReceiver"
            android:exported="true">
            <!-- Listen for device attach/detach -->
            <intent-filter>
                <action android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED" />
                <action android:name="android.hardware.usb.action.USB_DEVICE_DETACHED" />
            </intent-filter>
            <!-- Link to device filter - tells Android which devices we support -->
            <meta-data
                android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED"
                android:resource="@xml/device_filter" />
        </receiver>

        <!-- ✅ USB PERMISSION REQUEST RECEIVER -->
        <!-- Handles user's response to permission dialog -->
        <receiver
            android:name="com.shubham.rcreceiver.receivers.UsbPermissionReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.shubham.rcreceiver.USB_PERMISSION" />
            </intent-filter>
        </receiver>

        <!-- ✅ OPTIONAL: Activity to handle USB device directly -->
        <!-- This makes app appear in system's "Open with" menu for USB devices -->
        <activity-alias
            android:name="com.shubham.rcreceiver.UsbDeviceActivity"
            android:targetActivity="com.shubham.rcreceiver.presentation.MainActivity"
            android:exported="true">
            <!-- Intent filter for USB devices matching our filter -->
            <intent-filter>
                <action android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED" />
            </intent-filter>
            <!-- Link to device filter -->
            <meta-data
                android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED"
                android:resource="@xml/device_filter" />
        </activity-alias>
    </application>

</manifest>